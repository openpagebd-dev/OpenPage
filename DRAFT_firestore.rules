rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Primitives
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Explicit Admin Check (Email and DB verification)
    function isAdmin() {
      return isSignedIn() &&
        ((request.auth.token.email == "openpagebd@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['reader', 'contributor', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'authorId', 'status', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.category is string && data.category.size() <= 50 &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.status in ['pending', 'published'] &&
             data.createdAt is timestamp;
    }

    function isValidEmergency(data) {
      return data.keys().hasAll(['type', 'title', 'status', 'createdAt']) &&
             data.type in ['emergency', 'blood_request'] &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['active', 'resolved'] &&
             data.createdAt is timestamp;
    }

    function isValidCause(data) {
      return data.keys().hasAll(['title', 'description', 'goalAmount', 'currentAmount', 'supporters', 'urgent', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.goalAmount is number &&
             data.currentAmount is number &&
             data.supporters is number &&
             data.urgent is bool &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Match Groups
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().role == 'reader' &&
                      incoming().uid == userId &&
                      incoming().createdAt == request.time &&
                      isValidUser(incoming()) &&
                      incoming().keys().size() == 4; // Strict creation
      allow update: if isAdmin() || (
        isOwner(userId) && 
        incoming().role == existing().role && 
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        isValidUser(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bloodGroup', 'isDonor', 'updatedAt'])
      );
    }

    match /articles/{articleId} {
      allow read: if existing().status == 'published' || isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
      
      allow create: if isSignedIn() && 
                    incoming().authorId == request.auth.uid &&
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time &&
                    isValidArticle(incoming()) &&
                    incoming().keys().size() >= 6 && incoming().keys().size() <= 12;
                    
      allow update: if isAdmin() || (
        isSignedIn() && 
        isValidArticle(incoming()) &&
        existing().authorId == request.auth.uid &&
        incoming().authorId == existing().authorId &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time && (
          // Action: Update content while pending
          (existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'imageUrl', 'media', 'itemStatus', 'updatedAt', 'authorName', 'reactions', 'comments', 'views'])) ||
          // Action: Global interactions (any status)
          (incoming().diff(existing()).affectedKeys().hasOnly(['reactions', 'comments', 'views', 'updatedAt', 'itemStatus']))
        )
      );

      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid && existing().status == 'pending');
    }

    match /emergencies/{emergencyId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().createdAt == request.time && isValidEmergency(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && 
        isValidEmergency(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'description', 'contactInfo', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /causes/{causeId} {
      allow read: if true;
      allow create: if isAdmin() && incoming().createdAt == request.time && isValidCause(incoming());
      allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['currentAmount', 'supporters', 'updatedAt'])) || isAdmin();
      allow delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create: if isAdmin() && incoming().createdAt == request.time;
      allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['options', 'votes', 'updatedAt'])) || isAdmin();
      allow delete: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
      allow write: if false;
    }
  }
}

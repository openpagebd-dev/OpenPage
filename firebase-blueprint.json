{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["reader", "contributor", "admin"] },
        "bloodGroup": { "type": "string", "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
        "isDonor": { "type": "boolean" },
        "location": { "type": "object" },
        "reputation": { "type": "number" },
        "xp": { "type": "number" },
        "rank": { "type": "string" },
        "commendationsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Article": {
      "title": "Article",
      "description": "News article or editorial content.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "views": { "type": "number" },
        "reactions": { "type": "object" },
        "location": { "type": "object" },
        "itemStatus": { "type": "string", "enum": ["Pending", "Solved", "Failed"] },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "authorId", "status"]
    },
    "Emergency": {
      "title": "Emergency",
      "description": "Emergency alert or blood request.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["emergency", "blood_request"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "object" },
        "radius": { "type": "number" },
        "contactInfo": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "hospital": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "acceptedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "location", "status"]
    },
    "SupplyNode": {
      "title": "Supply Node",
      "description": "Pharmacy, Oxygen Bank, or Shelter.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Pharmacy", "Oxygen Bank", "Shelter", "Food Bank"] },
        "status": { "type": "string", "enum": ["Available", "Low Stock", "Out of Stock"] },
        "location": { "type": "object" },
        "contact": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "status", "location"]
    },
    "SystemBriefing": {
      "title": "System Briefing",
      "description": "AI generated tactical summary.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mood": { "type": "string" }
      },
      "required": ["content", "timestamp"]
    },
    "Poll": {
      "title": "Poll",
      "description": "Community public opinion poll.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "votes": { "type": "object" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "options", "active"]
    },
    "Ad": {
      "title": "Ad",
      "description": "Advertisement creative configuration.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "script"] },
        "content": { "type": "string" },
        "placement": { "type": "string", "enum": ["home_banner", "sidebar", "article_middle"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "content", "placement", "active"]
    },
    "Cause": {
      "title": "Cause",
      "description": "Humanitarian or community support cause.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "goalAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "supporters": { "type": "number" },
        "urgent": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "goalAmount", "currentAmount", "supporters", "urgent"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "articles/{articleId}": {
      "schema": "Article",
      "description": "News and editorial content."
    },
    "emergencies/{emergencyId}": {
      "schema": "Emergency",
      "description": "Emergency alerts and blood requests."
    },
    "supplyNodes/{nodeId}": {
      "schema": "SupplyNode",
      "description": "Critical supply nodes like oxygen or pharmacies."
    },
    "briefings/{briefingId}": {
      "schema": "SystemBriefing",
      "description": "AI-generated tactical briefings."
    },
    "polls/{pollId}": {
      "schema": "Poll",
      "description": "Community polls."
    },
    "ads/{adId}": {
      "schema": "Ad",
      "description": "Ad network creatives."
    },
    "causes/{causeId}": {
      "schema": "Cause",
      "description": "Humanitarian causes."
    },
    "settings/global": {
      "schema": "object",
      "description": "Global app settings including ad kill switch."
    }
  }
}
